rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users can read/write their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Admins can read all users (for dashboard)
    match /users/{userId} {
      allow read: if request.auth != null && 
        exists(/databases/$(database)/documents/admins/$(request.auth.token.email)) &&
        get(/databases/$(database)/documents/admins/$(request.auth.token.email)).data.isAdmin == true;
    }
    
    // Users can check if they are admin
    match /admins/{email} {
      allow read: if request.auth != null && request.auth.token.email == email;
    }
    
    // Custom symptoms - everyone can read, only admins can write
    match /customSymptoms/{symptomId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null && 
        exists(/databases/$(database)/documents/admins/$(request.auth.token.email)) &&
        get(/databases/$(database)/documents/admins/$(request.auth.token.email)).data.isAdmin == true;
    }
    
    // Custom remedies - everyone can read, only admins can write
    match /remedies/{remedyId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null && 
        exists(/databases/$(database)/documents/admins/$(request.auth.token.email)) &&
        get(/databases/$(database)/documents/admins/$(request.auth.token.email)).data.isAdmin == true;
    }
    
    // Symptom overrides (for editing static symptoms) - everyone can read, only admins can write
    match /symptomOverrides/{overrideId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null && 
        exists(/databases/$(database)/documents/admins/$(request.auth.token.email)) &&
        get(/databases/$(database)/documents/admins/$(request.auth.token.email)).data.isAdmin == true;
    }
  }
}
